# MongoDB connection string
# Option 1: MongoDB Atlas (recommended)
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/stock_radar?retryWrites=true&w=majority
# Option 2: Local MongoDB
MONGO_URI=mongodb://localhost:27017/stock_radar

# Finnhub API Key — get a free key at https://finnhub.io
# If left blank or set to "demo", mock prices will be used
FINNHUB_API_KEY=your_finnhub_api_key_here

# Port for the Express server
PORT=5000

# Comma-separated list of subreddits to scrape
SUBREDDITS=wallstreetbets,stocks,investing

# How often to run the ingestion cron job (cron syntax, default every 15 min)
CRON_SCHEDULE=*/15 * * * *
